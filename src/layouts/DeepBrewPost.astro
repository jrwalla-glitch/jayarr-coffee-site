---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import DeepBrewHeader from '../components/DeepBrewHeader.astro';
import DeepBrewFooter from '../components/DeepBrewFooter.astro';
import DeepBrewRelated from '../components/DeepBrewRelated.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE } from '../consts';

type Props = CollectionEntry<'deepbrew'>['data'] & { id: string };

const { title, description, pubDate, updatedDate, category, id } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const articleSchema = {
	'@context': 'https://schema.org',
	'@type': 'Article',
	headline: title,
	description: description,
	datePublished: pubDate.toISOString(),
	dateModified: (updatedDate ?? pubDate).toISOString(),
	author: {
		'@type': 'Person',
		name: 'Jay Arr',
		url: Astro.site?.toString(),
	},
	publisher: {
		'@type': 'Organization',
		name: SITE_TITLE,
		url: Astro.site?.toString(),
	},
	mainEntityOfPage: {
		'@type': 'WebPage',
		'@id': canonicalURL.toString(),
	},
};

const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Home',
			item: Astro.site?.toString(),
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Deep Brew',
			item: new URL('/deep-brew/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: 'Research',
			item: new URL('/deep-brew/research/', Astro.site).toString(),
		},
		{
			'@type': 'ListItem',
			position: 4,
			name: title,
			item: canonicalURL.toString(),
		},
	],
};
---

<html lang="en">
	<head>
		<BaseHead
			title={`${title} | Deep Brew`}
			description={description}
			isArticle={true}
			pubDate={pubDate}
			updatedDate={updatedDate}
		/>
		<script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
		<script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
	</head>
	<body class="bg-db-bg text-db-text font-sans antialiased" style="background-color: var(--color-db-bg); color: var(--color-db-text);">
		<DeepBrewHeader />

		<!-- Breadcrumbs -->
		<div class="pt-24 pb-0">
			<nav class="max-w-3xl mx-auto px-6" aria-label="Breadcrumb">
				<ol class="flex items-center gap-2 text-xs text-db-text-muted/40">
					<li><a href="/deep-brew/" class="hover:text-db-text-muted/60 transition-colors">Deep Brew</a></li>
					<li class="select-none">/</li>
					<li><a href="/deep-brew/research/" class="hover:text-db-text-muted/60 transition-colors">Research</a></li>
					{category && (
						<>
							<li class="select-none">/</li>
							<li class="text-db-copper/70">{category}</li>
						</>
					)}
				</ol>
			</nav>
		</div>

		<!-- Article header -->
		<div class="pt-6 pb-12">
			<div class="max-w-3xl mx-auto px-6 text-center">
				{category && (
					<span class="inline-block font-db-mono text-[10px] uppercase tracking-[0.15em] text-db-copper/70 bg-db-copper/10 px-2 py-0.5 rounded mb-3">
						{category}
					</span>
				)}
				<div class="flex items-center justify-center gap-3 text-xs uppercase tracking-widest text-db-text-muted/50 font-db-mono">
					<time>
						<FormattedDate date={pubDate} />
					</time>
					{updatedDate && (
						<span class="text-db-text-muted/40">
							(Updated <FormattedDate date={updatedDate} />)
						</span>
					)}
					<span class="text-db-text-muted/30">|</span>
					<span id="read-time" class="text-db-text-muted/40"></span>
				</div>
				<h1 class="font-db-serif text-4xl md:text-5xl lg:text-6xl font-bold mt-4 leading-tight"
						style="background: linear-gradient(135deg, var(--color-db-text) 0%, var(--color-db-copper) 100%); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">
					{title}
				</h1>
				{description && (
					<p class="text-lg text-db-text-muted mt-4 max-w-2xl mx-auto leading-relaxed">{description}</p>
				)}
			</div>
		</div>

		<!-- Divider -->
		<div class="max-w-3xl mx-auto px-6">
			<div class="h-px" style="background: linear-gradient(90deg, transparent, var(--color-db-copper), transparent); opacity: 0.3;"></div>
		</div>

		<!-- Table of Contents -->
		<nav id="toc" class="hidden max-w-[720px] mx-auto px-6 mt-10 mb-2">
			<details class="bg-db-surface rounded-lg p-5 group border border-db-border" open>
				<summary class="cursor-pointer text-xs uppercase tracking-widest text-db-text-muted font-db-mono font-medium select-none list-none flex items-center justify-between">
					<span>In This Article</span>
					<svg class="w-4 h-4 transition-transform group-open:rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
				</summary>
				<ol id="toc-list" class="mt-4 flex flex-col gap-2 text-sm"></ol>
			</details>
		</nav>

		<!-- Article body -->
		<main class="py-16 px-6">
			<article class="db-prose" id="article-content">
				<slot />
			</article>

			<!-- Related Posts -->
			<div class="max-w-[720px] mx-auto mt-16">
				<DeepBrewRelated currentId={id} category={category} />
			</div>
		</main>

		<DeepBrewFooter />

		<!-- Read time + Table of Contents script -->
		<script>
			const article = document.getElementById('article-content');
			const toc = document.getElementById('toc');
			const tocList = document.getElementById('toc-list');
			const readTimeEl = document.getElementById('read-time');

			if (article) {
				const text = article.textContent || '';
				const words = text.trim().split(/\s+/).length;
				const minutes = Math.max(1, Math.round(words / 230));
				if (readTimeEl) {
					readTimeEl.textContent = `${minutes} min read`;
				}

				if (toc && tocList) {
					const headings = article.querySelectorAll('h2');
					if (headings.length >= 3) {
						toc.classList.remove('hidden');
						headings.forEach((heading, i) => {
							const id = heading.id || `section-${i}`;
							heading.id = id;
							const li = document.createElement('li');
							const a = document.createElement('a');
							a.href = `#${id}`;
							a.textContent = heading.textContent;
							a.className = 'text-db-copper hover:text-db-copper-hover transition-colors';
							li.appendChild(a);
							tocList.appendChild(li);
						});
					}
				}
			}
		</script>

		<style is:global>
			/* Deep Brew prose styles */
			.db-prose {
				max-width: 720px;
				margin: 0 auto;
				font-size: 1.0625rem;
				line-height: 1.8;
				color: var(--color-db-text-muted, #94A3B8);
			}

			.db-prose h2 {
				font-family: 'Cormorant Garamond', Georgia, serif;
				font-weight: 700;
				font-size: 1.875rem;
				color: var(--color-db-text, #E2E8F0);
				margin: 3rem 0 1rem;
				line-height: 1.3;
			}

			.db-prose h3 {
				font-family: 'Cormorant Garamond', Georgia, serif;
				font-weight: 600;
				font-size: 1.375rem;
				color: var(--color-db-text, #E2E8F0);
				margin: 2rem 0 0.75rem;
				line-height: 1.4;
			}

			.db-prose p {
				margin: 0 0 1.25rem;
			}

			.db-prose strong {
				color: var(--color-db-text, #E2E8F0);
				font-weight: 600;
			}

			.db-prose em {
				font-style: italic;
			}

			.db-prose a {
				color: var(--color-db-copper, #D27D2D);
				text-decoration: underline;
				text-underline-offset: 2px;
				transition: color 0.2s;
			}

			.db-prose a:hover {
				color: var(--color-db-copper-hover, #E89144);
			}

			.db-prose ul, .db-prose ol {
				margin: 0 0 1.25rem;
				padding-left: 1.5rem;
			}

			.db-prose li {
				margin-bottom: 0.5rem;
			}

			.db-prose ul li::marker {
				color: var(--color-db-copper, #D27D2D);
			}

			.db-prose ol li::marker {
				color: var(--color-db-copper, #D27D2D);
				font-weight: 600;
			}

			.db-prose blockquote {
				border-left: 3px solid var(--color-db-copper, #D27D2D);
				padding-left: 1.25rem;
				margin: 1.5rem 0;
				color: var(--color-db-text-muted, #94A3B8);
				font-style: italic;
			}

			.db-prose code {
				font-family: 'JetBrains Mono', monospace;
				font-size: 0.875em;
				background: var(--color-db-surface, #161B22);
				border: 1px solid rgba(210, 125, 45, 0.15);
				border-radius: 3px;
				padding: 0.125em 0.375em;
				color: var(--color-db-copper, #D27D2D);
			}

			.db-prose hr {
				border: none;
				height: 1px;
				background: rgba(210, 125, 45, 0.15);
				margin: 2.5rem 0;
			}

			.db-prose table {
				width: 100%;
				border-collapse: collapse;
				margin: 1.5rem 0;
				font-size: 0.9375rem;
			}

			.db-prose thead tr {
				border-bottom: 2px solid var(--color-db-copper, #D27D2D);
			}

			.db-prose th {
				font-family: 'JetBrains Mono', monospace;
				font-weight: 500;
				font-size: 0.6875rem;
				letter-spacing: 1px;
				text-transform: uppercase;
				color: var(--color-db-text-muted, #94A3B8);
				padding: 0.75rem 0.625rem;
				text-align: left;
			}

			.db-prose td {
				padding: 0.75rem 0.625rem;
				border-bottom: 1px solid rgba(210, 125, 45, 0.1);
				color: var(--color-db-text-muted, #94A3B8);
			}

			.db-prose img {
				max-width: 100%;
				border-radius: 6px;
			}

			/* References section styling */
			.db-prose h2#references + ol,
			.db-prose h2:last-of-type + ol {
				font-size: 0.875rem;
				color: var(--color-db-text-muted, #94A3B8);
				opacity: 0.8;
			}

			.db-prose h2#references + ol li,
			.db-prose h2:last-of-type + ol li {
				margin-bottom: 0.375rem;
			}
		</style>
	</body>
</html>
