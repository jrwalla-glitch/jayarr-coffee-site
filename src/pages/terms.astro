---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Terms of Service — ${SITE_TITLE}`} description="Terms of service for JayArr Coffee. Rules and guidelines for using our website." />
	</head>
	<body class="bg-cream">
		<Header />

		<!-- Page header -->
		<div class="pt-32 pb-16 bg-charcoal">
			<div class="max-w-6xl mx-auto px-6">
				<span class="text-xs uppercase tracking-widest text-copper font-medium">Legal</span>
				<h1 class="font-serif text-5xl md:text-6xl font-bold text-cream mt-2">Terms of Service</h1>
			</div>
		</div>

		<main class="py-16 px-6">
			<div class="prose">
				<p><strong>Last updated:</strong> March 11, 2026</p>

				<p>
					Welcome to JayArr Coffee ("we," "us," or "our"). By accessing or using jayarr.coffee
					(the "Site"), you agree to these Terms of Service. If you do not agree, please do not
