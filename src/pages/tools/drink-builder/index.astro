---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import DrinkBuilder from '../../../components/tools/DrinkBuilder.svelte';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Espresso Drink Builder — JayArr Coffee"
			description="Visual guide to espresso drink proportions. See exactly what goes into a latte, cappuccino, cortado, flat white, americano, and more."
		/>
	</head>
	<body class="bg-cream">
		<Header />

		<section class="bg-charcoal pt-32 pb-12 md:pb-16">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<a href="/tools/" class="text-xs uppercase tracking-widest text-cream/40 hover:text-copper transition-colors">
					&larr; All Tools
				</a>
				<h1 class="font-serif text-3xl md:text-5xl font-bold text-cream mt-3 mb-3">Drink Builder</h1>
				<p class="text-cream/60 max-w-lg mx-auto leading-relaxed text-sm">
					See how every espresso drink is built — from a straight shot to a layered mocha.
				</p>
			</div>
		</section>

		<section class="py-12 md:py-16">
			<div class="max-w-xl mx-auto px-6">
				<DrinkBuilder client:load />
			</div>
		</section>

		<section class="bg-charcoal py-12">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<span class="text-xs uppercase tracking-widest text-copper font-medium">Learn More</span>
				<h2 class="font-serif text-xl md:text-2xl font-bold text-cream mt-2 mb-6">Related Articles</h2>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/blog/what-is-a-cortado/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Cortado Guide
					</a>
					<a href="/blog/what-is-a-flat-white-latte-vs-flat-white-comparison/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Flat White vs Latte
					</a>
					<a href="/blog/whats-different-about-ristretto-or-lungo-espresso-shots/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Espresso Shots
					</a>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
