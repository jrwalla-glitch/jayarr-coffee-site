---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FixMyCoffee from '../../../components/tools/FixMyCoffee.svelte';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Fix My Coffee — JayArr Coffee"
			description="Diagnose and fix common coffee brewing problems. Sour, bitter, weak, or muddy — find the science-backed fix for what went wrong."
		/>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebApplication",
			"name": "Fix My Coffee Diagnostic",
			"url": "https://jayarr.coffee/tools/fix-my-coffee/",
			"description": "Diagnose and fix common coffee brewing problems. Sour, bitter, weak, or muddy — find the science-backed fix for what went wrong.",
			"applicationCategory": "UtilityApplication",
			"operatingSystem": "Any",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			},
			"publisher": {
				"@type": "Organization",
				"name": "JayArr Coffee",
				"url": "https://jayarr.coffee"
			}
		})}></script>
	</head>
	<body class="bg-cream">
		<Header />

		<section class="bg-charcoal pt-32 pb-12 md:pb-16">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<a href="/tools/" class="text-xs uppercase tracking-widest text-cream/40 hover:text-copper transition-colors">
					&larr; All Tools
				</a>
				<h1 class="font-serif text-3xl md:text-5xl font-bold text-cream mt-3 mb-3">Fix My Coffee</h1>
				<p class="text-cream/60 max-w-lg mx-auto leading-relaxed text-sm">
					Something off with your brew? Pick a symptom and get science-backed fixes — in order of impact.
				</p>
			</div>
		</section>

		<section class="py-12 md:py-16">
			<div class="max-w-xl mx-auto px-6">
				<FixMyCoffee client:load />
			</div>
		</section>

		<section class="bg-charcoal py-12">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<span class="text-xs uppercase tracking-widest text-copper font-medium">Learn More</span>
				<h2 class="font-serif text-xl md:text-2xl font-bold text-cream mt-2 mb-6">Related Articles</h2>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/blog/coffee-extraction-yield-explained/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Extraction Science
					</a>
					<a href="/blog/coffee-grind-size-guide-what-grind-for-every-brew-method/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Grind Size Guide
					</a>
					<a href="/blog/why-water-matters-more-than-your-coffee-beans/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Water Science
					</a>
					<a href="/blog/coffee-strength-vs-extraction/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Strength vs Extraction
					</a>
					<a href="/blog/fix-channeling-uneven-extraction/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Fix Channeling
					</a>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
