---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import BrewRatio from '../../../components/tools/BrewRatio.svelte';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Brew Ratio Calculator — JayArr Coffee"
			description="Calculate the perfect coffee-to-water ratio for any brew method. Pour over, French press, AeroPress, cold brew, espresso, and more."
		/>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebApplication",
			"name": "Brew Ratio Calculator",
			"url": "https://jayarr.coffee/tools/brew-ratio/",
			"description": "Calculate the perfect coffee-to-water ratio for any brew method. Pour over, French press, AeroPress, cold brew, espresso, and more.",
			"applicationCategory": "UtilityApplication",
			"operatingSystem": "Any",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			},
			"publisher": {
				"@type": "Organization",
				"name": "JayArr Coffee",
				"url": "https://jayarr.coffee"
			}
		})}></script>
	</head>
	<body class="bg-cream">
		<Header />

		<!-- Hero -->
		<section class="bg-charcoal pt-32 pb-12 md:pb-16">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<a href="/tools/" class="text-xs uppercase tracking-widest text-cream/40 hover:text-copper transition-colors">
					&larr; All Tools
				</a>
				<h1 class="font-serif text-3xl md:text-5xl font-bold text-cream mt-3 mb-3">Brew Ratio Calculator</h1>
				<p class="text-cream/60 max-w-lg mx-auto leading-relaxed text-sm">
					Dial in the perfect coffee-to-water ratio for any brew method. Adjust to taste.
				</p>
			</div>
		</section>

		<!-- Calculator -->
		<section class="py-12 md:py-16">
			<div class="max-w-xl mx-auto px-6">
				<BrewRatio client:load />
			</div>
		</section>

		<!-- Related articles -->
		<section class="bg-charcoal py-12">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<span class="text-xs uppercase tracking-widest text-copper font-medium">Learn More</span>
				<h2 class="font-serif text-xl md:text-2xl font-bold text-cream mt-2 mb-6">Related Articles</h2>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/blog/ultimate-pour-over-coffee-guide-and-best-v60-technique/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Pour Over Guide
					</a>
					<a href="/blog/how-to-use-a-french-press-the-most-amazing-coffee-youve-ever-had/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						French Press Guide
					</a>
					<a href="/blog/why-water-matters-more-than-your-coffee-beans/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Water Science
					</a>
					<a href="/blog/coffee-to-water-ratio-guide/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Coffee-to-Water Ratio Guide
					</a>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
