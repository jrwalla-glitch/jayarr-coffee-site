---
import BaseHead from '../../../components/BaseHead.astro';
import Header from '../../../components/Header.astro';
import Footer from '../../../components/Footer.astro';
import FreshnessTracker from '../../../components/tools/FreshnessTracker.svelte';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title="Coffee Freshness Tracker — JayArr Coffee"
			description="Enter your roast date and see exactly where your beans are in their freshness lifecycle. Know when to brew, when to freeze, and when to buy fresh."
		/>
		<script type="application/ld+json" set:html={JSON.stringify({
			"@context": "https://schema.org",
			"@type": "WebApplication",
			"name": "Coffee Freshness Tracker",
			"url": "https://jayarr.coffee/tools/freshness/",
			"description": "Enter your roast date and see exactly where your beans are in their freshness lifecycle. Know when to brew, when to freeze, and when to buy fresh.",
			"applicationCategory": "UtilityApplication",
			"operatingSystem": "Any",
			"offers": {
				"@type": "Offer",
				"price": "0",
				"priceCurrency": "USD"
			},
			"publisher": {
				"@type": "Organization",
				"name": "JayArr Coffee",
				"url": "https://jayarr.coffee"
			}
		})}></script>
	</head>
	<body class="bg-cream">
		<Header />

		<section class="bg-charcoal pt-32 pb-12 md:pb-16">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<a href="/tools/" class="text-xs uppercase tracking-widest text-cream/40 hover:text-copper transition-colors">
					&larr; All Tools
				</a>
				<h1 class="font-serif text-3xl md:text-5xl font-bold text-cream mt-3 mb-3">Freshness Tracker</h1>
				<p class="text-cream/60 max-w-lg mx-auto leading-relaxed text-sm">
					Enter your roast date. See where your beans are in their lifecycle — and what to do about it.
				</p>
			</div>
		</section>

		<section class="py-12 md:py-16">
			<div class="max-w-xl mx-auto px-6">
				<FreshnessTracker client:load />
			</div>
		</section>

		<section class="bg-charcoal py-12">
			<div class="max-w-3xl mx-auto px-6 text-center">
				<span class="text-xs uppercase tracking-widest text-copper font-medium">Learn More</span>
				<h2 class="font-serif text-xl md:text-2xl font-bold text-cream mt-2 mb-6">Related Articles</h2>
				<div class="flex flex-wrap justify-center gap-4">
					<a href="/blog/coffee-freshness-roast-to-stale/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Freshness Science
					</a>
					<a href="/blog/single-dose-coffee-freezing-guide/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Freezing Guide
					</a>
					<a href="/blog/how-is-coffee-roasted/" class="border border-cream/20 text-cream/70 px-5 py-2 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-cream transition-all">
						Roasting Explained
					</a>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>
