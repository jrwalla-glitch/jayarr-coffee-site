---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ExploreGallery from '../components/ExploreGallery.svelte';
---

<html lang="en">
  <head>
    <BaseHead
      title="Explore — The Coffee Collection | JayArr Coffee"
      description="Three interactive studies in coffee science. Explore origins on our world map, discover brewing methods through star constellations, and find your perfect flavor with our botanical tasting guide."
    />
  </head>
  <body class="bg-cream">
    <Header />

    <main class="pt-20 pb-20">
      <ExploreGallery client:load />
    </main>

    <Footer />
  </body>
</html>
