---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ExploreGallery from '../components/ExploreGallery.svelte';
---

<html lang="en">
  <head>
    <BaseHead
      title="Explore — The Coffee Collection | JayArr Coffee"
      description="Three interactive studies in coffee science. Explore origins on our world map, discover brewing methods through constellations, and find your perfect flavor."
    />
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "WebApplication",
      "name": "The Coffee Collection",
      "url": "https://jayarr.coffee/explore/",
      "description": "Three interactive studies in coffee science. Explore origins on our world map, discover brewing methods through constellations, and find your perfect flavor.",
      "applicationCategory": "EducationalApplication",
      "operatingSystem": "Any",
      "offers": {
        "@type": "Offer",
        "price": "0",
        "priceCurrency": "USD"
      },
      "publisher": {
        "@type": "Organization",
        "name": "JayArr Coffee",
        "url": "https://jayarr.coffee"
      }
    })}></script>
  </head>
  <body class="bg-cream">
    <Header />

    <main class="pt-20 pb-20">
      <h1 class="sr-only">The Coffee Collection</h1>
      <ExploreGallery client:load />
    </main>

    <Footer />
  </body>
</html>
