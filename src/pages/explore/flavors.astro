---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FlavorBloom from '../../components/FlavorBloom.svelte';
---

<html lang="en">
  <head>
    <BaseHead
      title="Flavor Bloom — Discover Your Coffee Flavor | JayArr Coffee"
      description="Explore coffee flavors with our interactive Flavor Bloom. Find your perfect coffee by flavor profile — fruity, floral, sweet, nutty, spiced, or earthy."
    />
  </head>
  <body class="bg-cream">
    <Header />

    <main class="pt-20 pb-20">
      <FlavorBloom client:load />
    </main>

    <Footer />
  </body>
</html>
