---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import CoffeeMap from '../../components/CoffeeMap.svelte';
---

<html lang="en">
  <head>
    <BaseHead
      title="Coffee Origin Map — Explore Where Coffee Grows | JayArr Coffee"
      description="Explore coffee origins across the globe with our interactive map. Click any country to discover its coffee story — flavor profiles, growing regions, harvest seasons, and in-depth articles."
    />
  </head>
  <body class="bg-cream">
    <Header />

    <main class="pt-20 pb-20">
      <CoffeeMap client:load />
    </main>

    <Footer />
  </body>
</html>
