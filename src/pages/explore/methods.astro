---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import BrewExplorer from '../../components/BrewExplorer.svelte';
---

<html lang="en">
  <head>
    <BaseHead
      title="Brew Explorer — The Brewing Constellations | JayArr Coffee"
      description="Explore coffee brewing methods through an interactive star chart. Click any constellation to discover the science behind pour over, French press, espresso, and more."
    />
  </head>
  <body class="bg-cream">
    <Header />

    <main class="pt-20 pb-20">
      <BrewExplorer client:load />
    </main>

    <Footer />
  </body>
</html>
