---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`About — ${SITE_TITLE}`} description="About JayArr Coffee — exploring specialty coffee through science, scoring, and honest reviews." />
	</head>
	<body class="bg-cream">
		<Header />

		<!-- Page header -->
		<div class="pt-32 pb-16 bg-charcoal">
			<div class="max-w-6xl mx-auto px-6">
				<span class="text-xs uppercase tracking-widest text-copper font-medium">The Story</span>
				<h1 class="font-serif text-5xl md:text-6xl font-bold text-cream mt-2">About</h1>
			</div>
		</div>

		<main class="py-16 px-6">
			<div class="prose">
				<p>
					JayArr Coffee is a media brand dedicated to exploring specialty coffee through science,
					scoring systems, and honest reviews. We believe great coffee starts with understanding —
					understanding the origins, the process, the chemistry, and the craft.
				</p>

				<h2>What We Do</h2>
				<p>
					Through long-form articles and YouTube videos, we break down the world of specialty coffee
					for enthusiasts who want to go deeper. From the 100-point scoring system used by professional
					cuppers to the water chemistry that makes or breaks your brew, we cover the topics that
					matter to people who take their coffee seriously.
				</p>

				<h2>The Channel</h2>
				<p>
					The JayArr Coffee YouTube channel is where our video content lives. Subscribe for in-depth
					reviews, brewing science explainers, and coffee education that respects your intelligence.
				</p>
				<p>
					<a href="https://www.youtube.com/@jayarrcoffee" target="_blank" rel="noopener">
						Subscribe on YouTube &rarr;
					</a>
				</p>
			</div>
		</main>

		<Footer />
	</body>
</html>
