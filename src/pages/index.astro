---
import { Image } from 'astro:assets';
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';
import heroImage from '../assets/blog/hero-coffee-farm.jpg';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
const latestPosts = allPosts.slice(0, 6);

// Popular posts — hand-picked high-value articles
const popularSlugs = [
	'coffee-grind-size-guide-what-grind-for-every-brew-method',
	'why-water-matters-more-than-your-coffee-beans',
	'ultimate-pour-over-coffee-guide-and-best-v60-technique',
	'whats-the-ideal-coffee-brewing-temperature',
	'why-and-how-you-should-use-an-aeropress',
	'how-to-use-a-french-press-the-most-amazing-coffee-youve-ever-had',
];
const popularPosts = popularSlugs
	.map(slug => allPosts.find(p => p.id === slug))
	.filter(Boolean);

---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<script type="application/ld+json" set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'WebSite',
			name: SITE_TITLE,
			url: 'https://jayarr.coffee',
			description: SITE_DESCRIPTION,
			potentialAction: {
				'@type': 'SearchAction',
				target: {
					'@type': 'EntryPoint',
					urlTemplate: 'https://jayarr.coffee/?s={search_term_string}',
				},
				'query-input': 'required name=search_term_string',
			},
			publisher: {
				'@type': 'Organization',
				name: SITE_TITLE,
				url: 'https://jayarr.coffee',
				logo: {
					'@type': 'ImageObject',
					url: 'https://jayarr.coffee/favicon.svg',
				},
			},
		})} />
	</head>
	<body class="bg-cream">
		<Header />

		<!-- Hero Section -->
		<section class="relative h-[85vh] md:h-screen min-h-[500px] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0">
				<Image
					src={heroImage}
					alt="Coffee farm at golden hour"
					width={1920}
					height={1080}
					class="w-full h-full object-cover object-center"
					loading="eager"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-charcoal/60 via-charcoal/30 to-charcoal/80"></div>
			</div>
			<div class="relative z-10 text-center px-6 max-w-4xl">
				<h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-bold text-cream mb-4 md:mb-6 leading-tight">
					JayArr Coffee
				</h1>
				<p class="text-lg md:text-xl text-cream/80 max-w-2xl mx-auto mb-6 md:mb-10 leading-relaxed">
					Exploring specialty coffee through science, scoring, and honest reviews. From origin to cup.
				</p>
				<div class="flex flex-col sm:flex-row justify-center items-center gap-4">
					<a href="/explore" class="inline-block bg-copper text-cream px-8 py-3 text-sm uppercase tracking-widest hover:bg-copper-dark transition-all duration-300">
						Explore the Collection
					</a>
					<a href="/blog" class="inline-block border border-cream/40 text-cream px-8 py-3 text-sm uppercase tracking-widest hover:bg-cream hover:text-charcoal transition-all duration-300">
						Read Articles
					</a>
				</div>
			</div>
			<!-- Deep Brew Mode toggle -->
			<div class="absolute bottom-8 right-6 md:right-10 z-10">
				<a href="/deep-brew"
					class="group flex items-center gap-2 px-4 py-2 rounded-full border border-cream/20 bg-charcoal/40 backdrop-blur-sm hover:border-amber-400/50 hover:bg-charcoal/60 transition-all duration-300"
				>
					<span class="w-2 h-2 rounded-full bg-amber-400 animate-pulse"></span>
					<span class="text-xs text-cream/70 group-hover:text-amber-400 transition-colors uppercase tracking-widest font-medium">
						Deep Brew Mode
					</span>
				</a>
			</div>

			<!-- Scroll indicator -->
			<div class="absolute bottom-6 left-1/2 -translate-x-1/2 animate-bounce">
				<svg class="w-5 h-5 text-cream/40" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
			</div>
		</section>

		<!-- Latest Articles -->
		<section class="max-w-6xl mx-auto px-6 py-24">
			<div class="flex items-end justify-between mb-12">
				<div>
					<span class="text-xs uppercase tracking-widest text-copper font-medium">Latest</span>
					<h2 class="font-serif text-4xl md:text-5xl font-bold text-charcoal mt-2">Articles</h2>
				</div>
				<a href="/blog" class="text-sm text-copper hover:text-copper-dark transition-colors uppercase tracking-widest">
					View all &rarr;
				</a>
			</div>

			{latestPosts.length > 0 && (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
					{latestPosts.map((post) => (
						<a href={`/blog/${post.id}/`} class="group block">
							<article>
								{post.data.heroImage && (
									<div class="aspect-[16/10] overflow-hidden rounded-sm mb-4">
										<Image
											width={720}
											height={450}
											src={post.data.heroImage}
											alt={post.data.title}
											class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										/>
									</div>
								)}
								<div class="flex items-center gap-3 mb-1">
									{post.data.category && (
										<span class="text-xs uppercase tracking-widest text-copper">{post.data.category}</span>
									)}
									<time class="text-xs uppercase tracking-widest text-warm-gray">
										<FormattedDate date={post.data.pubDate} />
									</time>
								</div>
								<h3 class="font-serif text-xl font-bold text-charcoal mt-1 mb-2 group-hover:text-copper transition-colors">
									{post.data.title}
								</h3>
								{post.data.description && (
									<p class="text-sm text-warm-gray leading-relaxed line-clamp-2">
										{post.data.description}
									</p>
								)}
							</article>
						</a>
					))}
				</div>
			)}
		</section>

		<!-- Explore the Collection -->
		<section class="bg-charcoal py-24">
			<div class="max-w-6xl mx-auto px-6">
				<div class="text-center mb-14">
					<span class="text-xs uppercase tracking-widest text-copper font-medium">Discover</span>
					<h2 class="font-serif text-4xl md:text-5xl font-bold text-cream mt-2">Beyond the Articles</h2>
					<p class="text-cream/50 mt-3 text-sm max-w-xl mx-auto">Interactive tools and visual explorations that go deeper than reading</p>
				</div>

				<!-- The Coffee Collection -->
				<div class="mb-16">
					<h3 class="font-serif text-2xl font-bold text-cream text-center mb-2">The Coffee Collection</h3>
					<p class="text-cream/40 text-sm text-center mb-8 italic">Three interactive studies in coffee science</p>
					<div class="flex flex-col md:flex-row justify-center gap-6 md:gap-8 items-center">
						<a href="/explore/origins" class="group block text-center">
							<div class="w-52 h-32 bg-[#E8E1D4] border border-white/15 rounded-sm overflow-hidden relative mx-auto" style="box-shadow: inset 0 2px 6px rgba(0,0,0,0.08), 0 2px 8px rgba(0,0,0,0.15);">
								<svg viewBox="0 0 300 180" class="w-full h-full">
									<rect width="300" height="180" fill="#CBCFD5" rx="1"/>
									<g transform="scale(0.95) translate(8, 5)">
										<path d="M47.6,43.1L43.8,40.7L37.1,27.5L35.5,29L32.5,26.7L32.5,7.9L36.2,9.8L43.2,6L54,9.8L59.3,13.2L65.5,12.7L69.9,13.4L77.2,13.6L82.3,9.2L82.2,13.8L78.5,15L71.5,25.7L73.1,31.8L81.5,34.7L83.4,40.2L86.2,32.7L88.5,23L93.6,30.1L98.5,33L103.5,37.4L92.3,45L81.3,51.8L79.9,46.2L71,42.6L47.6,43.1Z M47.6,43.1L76.4,44L81.2,47.6L92.3,45L86.9,58.3L82.2,62.4L83,68.3L68.7,67.7L61.2,62.1L49.5,59.3L46.3,53.3L47.6,43.1Z M32.5,7.9L32.5,26.7L35.5,29L41.2,35.3L38.3,30.2L27.4,25.7L18,33.5L12.7,35.8L15,29.4L12.2,26.3L16,18.6L9.9,16.8L11.5,9.9L19.5,3.8L32.5,7.9Z" fill="#C9B99A" opacity="0.7"/>
										<path d="M105.5,119.9L102,116.4L101.5,103.7L91.2,99.2L91.8,88.6L99.8,85.6L107.3,86.5L116.7,92.4L121.1,96.1L115.9,108.7L105.5,119.9Z M102,116.4L102.7,123.1L93.2,141.3L88.8,137.3L92,104.9Z" fill="#C9B99A" opacity="0.7"/>
										<path d="M155.2,42.5L156.2,49.5L148.7,50.3L146.2,43.5L155.2,42.5Z M161.8,36.7L160.8,45L155,39.4L161.8,36.7Z M176.5,39L183.4,42.3L173.9,47.6L168.4,43.8L176.5,39Z" fill="#C9B99A" opacity="0.65"/>
										<path d="M142.8,66.3L149,58.1L156.1,56.7L160,69.9L142.8,66.3Z M170.8,71.2L159.6,60.8L170.8,62L170.8,71.2Z M170.5,83.1L170.8,71.2L182,74.8L178.3,82.7L170.5,83.1Z M174.5,93.8L174.8,101.1L160.1,94.8L166.2,85.8L174.8,86.2L174.5,93.8Z M163.6,114.8L174.5,108.9L177.4,113.1L166.4,121L163.6,114.8Z" fill="#C9B99A" opacity="0.7"/>
										<path d="M190.9,46.3L183.4,42.3L176.5,39L173.5,33.2L176.3,22.2L173.8,9.5L183.6,12L186.2,10.6L188.6,14.8L200,11.3L207.1,11.7L210.7,1.5L217.9,2.8L234,-11.5L245.1,-9.5L255.8,-2.3L266.6,3.5L274.6,1.6L284.1,8.6L300,9.7L300,18.2L291.9,27.4L285.1,35.2L280.7,40.5L268.5,28.8L262.6,35.3L261.3,50.5L259.2,48L253,37.1L248.2,42.4L232.4,39.1L222.8,42.8L214.1,35.7L207.6,34.4L201.1,40.7L189.6,41.2L190.9,46.3Z M216.9,51L223.1,42.7L241.1,50.8L258.9,51L248,55L251.4,65.5L241.6,72.8L230.1,64.3L215.6,62.3L211.4,54.2L216.9,51Z M179.1,64.4L190.4,65.2L196,70.6L185.6,76.2L179.1,64.4Z" fill="#C9B99A" opacity="0.7"/>
										<path d="M255.1,118.4L245.9,120.3L245.1,108.6L258,102.6L263.7,99.9L268.8,98.9L277.6,112.5L275,123.6L264,121.4L255.1,118.4Z" fill="#C9B99A" opacity="0.65"/>
									</g>
								</svg>
							</div>
							<span class="block text-cream/70 text-sm mt-3 group-hover:text-copper transition-colors font-serif font-semibold">Coffee Origins</span>
						</a>
						<a href="/explore/methods" class="group block text-center">
							<div class="w-52 h-32 border border-white/15 rounded-sm overflow-hidden relative mx-auto" style="background: #2A3040; box-shadow: inset 0 2px 6px rgba(0,0,0,0.08), 0 2px 8px rgba(0,0,0,0.15);">
								<svg viewBox="0 0 300 180" class="w-full h-full">
									<rect width="300" height="180" fill="#0B1525"/>
									{[{x:22,y:18},{x:88,y:12},{x:178,y:22},{x:248,y:15},{x:268,y:55},{x:12,y:115},{x:138,y:152},{x:282,y:140}].map(s => (
										<circle cx={s.x} cy={s.y} r="0.6" fill="#E8E0D0" opacity="0.25"/>
									))}
									<line x1="40" y1="48" x2="82" y2="44" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<line x1="82" y1="44" x2="62" y2="78" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<line x1="40" y1="48" x2="62" y2="78" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<line x1="62" y1="78" x2="62" y2="115" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<circle cx="40" cy="48" r="2.2" fill="#E8C36A" opacity="0.8"/>
									<circle cx="82" cy="44" r="2" fill="#E8C36A" opacity="0.75"/>
									<circle cx="62" cy="78" r="3" fill="#D4A44C" opacity="0.9"/>
									<circle cx="62" cy="115" r="2" fill="#E8C36A" opacity="0.75"/>
									<line x1="128" y1="48" x2="172" y2="48" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<line x1="128" y1="48" x2="122" y2="90" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<line x1="172" y1="48" x2="178" y2="90" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<line x1="122" y1="90" x2="150" y2="122" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<line x1="178" y1="90" x2="150" y2="122" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<circle cx="128" cy="48" r="2" fill="#E8C36A" opacity="0.75"/>
									<circle cx="172" cy="48" r="2" fill="#E8C36A" opacity="0.75"/>
									<circle cx="150" cy="85" r="3" fill="#D4A44C" opacity="0.9"/>
									<circle cx="150" cy="122" r="2" fill="#E8C36A" opacity="0.75"/>
									<line x1="222" y1="45" x2="258" y2="80" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<line x1="258" y1="80" x2="222" y2="118" stroke="#C9A84E" stroke-width="0.6" opacity="0.4"/>
									<circle cx="222" cy="45" r="2" fill="#E8C36A" opacity="0.75"/>
									<circle cx="258" cy="80" r="3" fill="#D4A44C" opacity="0.9"/>
									<circle cx="222" cy="118" r="2" fill="#E8C36A" opacity="0.75"/>
								</svg>
							</div>
							<span class="block text-cream/70 text-sm mt-3 group-hover:text-copper transition-colors font-serif font-semibold">Brewing Constellations</span>
						</a>
						<a href="/explore/flavors" class="group block text-center">
							<div class="w-52 h-32 bg-[#DDE4D6] border border-white/15 rounded-sm overflow-hidden relative mx-auto" style="box-shadow: inset 0 2px 6px rgba(0,0,0,0.08), 0 2px 8px rgba(0,0,0,0.15);">
								<svg viewBox="0 0 300 180" class="w-full h-full">
									<defs>
										{[
											{ id: 'hf', c: '#C17A3A', l: '#D4944F' },
											{ id: 'hfl', c: '#B8847A', l: '#CCACA4' },
											{ id: 'hs', c: '#8B6F47', l: '#A6895E' },
											{ id: 'hn', c: '#A69070', l: '#BBA98D' },
											{ id: 'hsp', c: '#9B7653', l: '#B3926E' },
											{ id: 'he', c: '#7A7A60', l: '#96967E' },
										].map(g => (
											<radialGradient id={g.id} cx="50%" cy="50%" r="50%">
												<stop offset="0%" stop-color={g.c} stop-opacity="1"/>
												<stop offset="60%" stop-color={g.c} stop-opacity="0.92"/>
												<stop offset="85%" stop-color={g.l} stop-opacity="0.65"/>
												<stop offset="100%" stop-color={g.l} stop-opacity="0.35"/>
											</radialGradient>
										))}
									</defs>
									{[0,60,120,180,240,300].map((angle, i) => {
										const fills = ['url(#hf)','url(#hfl)','url(#hs)','url(#hn)','url(#hsp)','url(#he)'];
										const rad = angle * Math.PI / 180;
										const px = 150 + 26 * Math.sin(rad);
										const py = 90 - 26 * Math.cos(rad);
										return <ellipse cx={px} cy={py} rx="24" ry="33" fill={fills[i]} transform={`rotate(${angle}, ${px}, ${py})`}/>;
									})}
									<circle cx="150" cy="90" r="9" fill="#F5F0E8" stroke="#C17A3A" stroke-width="0.8"/>
								</svg>
							</div>
							<span class="block text-cream/70 text-sm mt-3 group-hover:text-copper transition-colors font-serif font-semibold">Flavor Bloom</span>
						</a>
					</div>
					<div class="text-center mt-8">
						<a href="/explore" class="inline-block border border-cream/25 text-cream/70 px-6 py-2.5 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-copper transition-all duration-300">
