					<div class="flex-1 h-px bg-white/10"></div>
					<span class="text-copper/40 text-xs tracking-widest uppercase">Plus</span>
					<div class="flex-1 h-px bg-white/10"></div>
				</div>

				<!-- Your Coffee Toolkit -->
				<div>
					<h3 class="font-serif text-2xl font-bold text-cream text-center mb-2">Your Coffee Toolkit</h3>
					<p class="text-cream/40 text-sm text-center mb-8 italic">Practical calculators and diagnostics for everyday brewing</p>
					<div class="grid grid-cols-1 sm:grid-cols-3 gap-5 max-w-3xl mx-auto">
						<a href="/tools/fix-my-coffee/" class="group block p-5 border border-white/10 rounded-sm hover:border-copper/40 transition-all duration-300">
							<div class="text-copper mb-2">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17 17.25 21A2.652 2.652 0 0 0 21 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 1 1-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 0 0 4.486-6.336l-3.276 3.277a3.004 3.004 0 0 1-2.25-2.25l3.276-3.276a4.5 4.5 0 0 0-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085"/></svg>
							</div>
							<h4 class="font-serif text-base font-bold text-cream group-hover:text-copper transition-colors mb-1">Fix My Coffee</h4>
							<p class="text-xs text-cream/50 leading-relaxed">Pick a symptom, get science-backed fixes</p>
						</a>
						<a href="/tools/brew-ratio/" class="group block p-5 border border-white/10 rounded-sm hover:border-copper/40 transition-all duration-300">
							<div class="text-copper mb-2">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v17.25m0 0c-1.472 0-2.882.265-4.185.75M12 20.25c1.472 0 2.882.265 4.185.75M18.75 4.97A48.416 48.416 0 0 0 12 4.5c-2.291 0-4.545.16-6.75.47m13.5 0c1.01.143 2.01.317 3 .52m-3-.52 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.988 5.988 0 0 1-2.031.352 5.988 5.988 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L18.75 4.971Zm-16.5.52c.99-.203 1.99-.377 3-.52m0 0 2.62 10.726c.122.499-.106 1.028-.589 1.202a5.989 5.989 0 0 1-2.031.352 5.989 5.989 0 0 1-2.031-.352c-.483-.174-.711-.703-.59-1.202L5.25 4.971Z"/></svg>
							</div>
							<h4 class="font-serif text-base font-bold text-cream group-hover:text-copper transition-colors mb-1">Brew Ratio</h4>
							<p class="text-xs text-cream/50 leading-relaxed">Dial in coffee-to-water for any method</p>
						</a>
						<a href="/tools/grind-guide/" class="group block p-5 border border-white/10 rounded-sm hover:border-copper/40 transition-all duration-300">
							<div class="text-copper mb-2">
								<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h9.75"/></svg>
							</div>
							<h4 class="font-serif text-base font-bold text-cream group-hover:text-copper transition-colors mb-1">Grind Guide</h4>
							<p class="text-xs text-cream/50 leading-relaxed">Micron ranges and textures for every brewer</p>
						</a>
					</div>
					<div class="text-center mt-8">
						<a href="/tools" class="inline-block border border-cream/25 text-cream/70 px-6 py-2.5 text-xs uppercase tracking-widest hover:border-copper/50 hover:text-copper transition-all duration-300">
							Open the Toolkit &rarr;
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Popular Articles -->
		<section class="max-w-6xl mx-auto px-6 py-24">
			<div class="text-center mb-12">
				<span class="text-xs uppercase tracking-widest text-copper font-medium">Start Here</span>
				<h2 class="font-serif text-4xl md:text-5xl font-bold text-charcoal mt-2">Popular Articles</h2>
			</div>
			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-8">
				{popularPosts.map((post) => post && (
					<a href={`/blog/${post.id}/`} class="group flex gap-4 items-start">
						{post.data.heroImage && (
							<div class="w-20 h-20 shrink-0 overflow-hidden rounded-sm">
