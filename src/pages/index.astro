							{post.data.category && (
								<span class="text-xs uppercase tracking-widest text-copper">{post.data.category}</span>
							)}
							<h3 class="font-serif text-base font-bold text-charcoal mt-0.5 group-hover:text-copper transition-colors leading-snug">
								{post.data.title}
							</h3>
						</div>
					</a>
