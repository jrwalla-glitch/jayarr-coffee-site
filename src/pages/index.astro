---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body class="bg-cream">
		<Header />

		<!-- Hero Section -->
		<section class="relative h-screen min-h-[600px] flex items-center justify-center overflow-hidden">
			<div class="absolute inset-0">
				<img
					src="/images/hero-coffee-farm.jpg"
					alt="Coffee farm at golden hour"
					class="w-full h-full object-cover"
				/>
				<div class="absolute inset-0 bg-gradient-to-b from-charcoal/60 via-charcoal/30 to-charcoal/80"></div>
			</div>
			<div class="relative z-10 text-center px-6 max-w-4xl">
				<h1 class="font-serif text-5xl md:text-7xl lg:text-8xl font-bold text-cream mb-6 leading-tight">
					JayArr Coffee
				</h1>
				<p class="text-lg md:text-xl text-cream/80 max-w-2xl mx-auto mb-10 leading-relaxed">
					Exploring specialty coffee through science, scoring, and honest reviews. From origin to cup.
				</p>
				<a href="/blog" class="inline-block border border-cream/40 text-cream px-8 py-3 text-sm uppercase tracking-widest hover:bg-cream hover:text-charcoal transition-all duration-300">
					Read Articles
				</a>
			</div>
			<!-- Scroll indicator -->
			<div class="absolute bottom-8 left-1/2 -translate-x-1/2 animate-bounce">
				<svg class="w-6 h-6 text-cream/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/></svg>
			</div>
		</section>

		<!-- Latest Articles -->
		<section class="max-w-6xl mx-auto px-6 py-24">
			<div class="flex items-end justify-between mb-12">
				<div>
					<span class="text-xs uppercase tracking-widest text-copper font-medium">Latest</span>
					<h2 class="font-serif text-4xl md:text-5xl font-bold text-charcoal mt-2">Articles</h2>
				</div>
				<a href="/blog" class="text-sm text-copper hover:text-copper-dark transition-colors uppercase tracking-widest">
					View all &rarr;
				</a>
			</div>

			{posts.length > 0 && (
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
					{posts.map((post) => (
						<a href={`/blog/${post.id}/`} class="group block">
							<article>
								{post.data.heroImage && (
									<div class="aspect-[16/10] overflow-hidden rounded-sm mb-4">
										<img
											src={post.data.heroImage.src}
											alt={post.data.title}
											class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
										/>
									</div>
								)}
								<time class="text-xs uppercase tracking-widest text-warm-gray">
									<FormattedDate date={post.data.pubDate} />
								</time>
								<h3 class="font-serif text-xl font-bold text-charcoal mt-1 mb-2 group-hover:text-copper transition-colors">
									{post.data.title}
								</h3>
								{post.data.description && (
									<p class="text-sm text-warm-gray leading-relaxed line-clamp-2">
										{post.data.description}
									</p>
								)}
							</article>
						</a>
					))}
				</div>
			)}
		</section>

		<!-- Featured Video Section -->
		<section class="bg-charcoal py-24">
			<div class="max-w-6xl mx-auto px-6">
				<div class="text-center mb-12">
					<span class="text-xs uppercase tracking-widest text-copper font-medium">Watch</span>
					<h2 class="font-serif text-4xl md:text-5xl font-bold text-cream mt-2">Featured Video</h2>
				</div>
				<div class="max-w-4xl mx-auto">
					<div class="aspect-video rounded-sm overflow-hidden">
						<iframe
							class="w-full h-full"
							src="https://www.youtube.com/embed?listType=user_uploads&list=jayarrcoffee"
							title="JayArr Coffee - Latest Video"
							frameborder="0"
							allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
							allowfullscreen
						></iframe>
					</div>
					<div class="text-center mt-8">
						<a href="https://www.youtube.com/@jayarrcoffee" target="_blank" rel="noopener" class="inline-block border border-cream/30 text-cream/80 px-8 py-3 text-sm uppercase tracking-widest hover:bg-cream hover:text-charcoal transition-all duration-300">
							Subscribe on YouTube
						</a>
					</div>
				</div>
			</div>
		</section>

		<!-- Newsletter CTA -->
		<section class="py-24 bg-cream-dark">
			<div class="max-w-2xl mx-auto px-6 text-center">
				<span class="text-xs uppercase tracking-widest text-copper font-medium">Stay Updated</span>
				<h2 class="font-serif text-3xl md:text-4xl font-bold text-charcoal mt-2 mb-4">
					Join the Newsletter
				</h2>
				<p class="text-warm-gray mb-8 leading-relaxed">
					Get new articles, video drops, and coffee insights delivered to your inbox. No spam, just good coffee content.
				</p>
				<form class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
					<input
						type="email"
						placeholder="your@email.com"
						class="flex-1 px-4 py-3 bg-cream border border-charcoal/20 text-charcoal placeholder:text-warm-gray/60 text-sm focus:outline-none focus:border-copper transition-colors"
					/>
					<button type="submit" class="bg-charcoal text-cream px-6 py-3 text-sm uppercase tracking-widest hover:bg-copper transition-colors">
						Subscribe
					</button>
				</form>
				<p class="text-xs text-warm-gray/60 mt-4">No spam. Unsubscribe anytime.</p>
			</div>
		</section>

		<Footer />
	</body>
</html>
