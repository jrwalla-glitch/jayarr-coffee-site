---
/**
 * RecipeSchema.astro — JSON-LD structured data for Recipe rich results
 *
 * Usage in an MDX blog post:
 *
 *   import RecipeSchema from '../../components/RecipeSchema.astro';
 *
 *   <RecipeSchema
 *     title="Cold Brew Coffee Concentrate"
 *     description="Smooth, low-acid cold brew concentrate you can make overnight with nothing but a jar, coffee, and water."
 *     image="https://jayarr.coffee/images/cold-brew.jpg"
 *     prepTime="PT5M"
 *     cookTime="PT12H"
 *     totalTime="PT12H5M"
 *     recipeYield="4 servings"
 *     recipeCategory="Beverage"
 *     recipeCuisine="American"
 *     recipeIngredient={[
 *       "100g coarsely ground coffee",
 *       "700ml cold filtered water",
 *     ]}
 *     recipeInstructions={[
 *       "Combine coffee grounds and water in a mason jar or French press.",
 *       "Stir gently to ensure all grounds are saturated.",
 *       "Cover and refrigerate for 12-24 hours.",
 *       "Strain through a fine-mesh sieve or paper filter.",
 *       "Dilute concentrate 1:1 with water or milk and serve over ice.",
 *     ]}
 *   />
 *
 * Required props: title, description, recipeIngredient
 * All other props are optional and will be omitted from the schema if not provided.
 * Time fields use ISO 8601 duration format (e.g., "PT30M" = 30 minutes, "PT1H" = 1 hour).
 */

interface Props {
	title: string;
	description: string;
	image?: string;
	prepTime?: string;
	cookTime?: string;
	totalTime?: string;
	recipeYield?: string;
	recipeCategory?: string;
	recipeCuisine?: string;
	recipeIngredient: string[];
	recipeInstructions?: string[];
	keywords?: string;
	videoId?: string;
	author?: string;
	nutrition?: {
		calories?: string;
		fatContent?: string;
		saturatedFatContent?: string;
		carbohydrateContent?: string;
		sugarContent?: string;
		proteinContent?: string;
		fiberContent?: string;
		sodiumContent?: string;
		servingSize?: string;
	};
}

const {
	title,
	description,
	image,
	prepTime,
	cookTime,
	totalTime,
	recipeYield,
	recipeCategory,
	recipeCuisine,
	recipeIngredient,
	recipeInstructions,
	keywords,
	videoId,
	author = 'JayArr',
	nutrition,
} = Astro.props;

// Derive fallback image from page URL slug → /images/blog/{slug}.jpg
const slug = Astro.url.pathname.replace(/^\/blog\//, '').replace(/\/$/, '');
const fallbackImage = slug ? new URL(`/images/blog/${slug}.jpg`, Astro.site).href : undefined;
const resolvedImage = image || fallbackImage;

// Auto-derive keywords from recipe title + category + cuisine + site context
const cleanTitle = title.toLowerCase().replace(/[()[\]]/g, '').replace(/\s+/g, ' ').trim();
const siteTopic = (Astro.site?.hostname || '').includes('coffee') ? 'coffee'
	: (Astro.site?.hostname || '').includes('pizza') ? 'pizza'
	: (Astro.site?.hostname || '').includes('bread') ? 'bread, baking'
	: (Astro.site?.hostname || '').includes('chocolate') || (Astro.site?.hostname || '').includes('cacao') ? 'chocolate, cacao'
	: '';
const autoKeywords = [cleanTitle, recipeCategory?.toLowerCase(), recipeCuisine?.toLowerCase(), siteTopic].filter(Boolean).join(', ');
const resolvedKeywords = keywords || autoKeywords;

// Generate VideoObject from YouTube video ID
const videoSchema = videoId ? {
	video: {
		'@type': 'VideoObject',
		name: title,
		description,
		thumbnailUrl: `https://img.youtube.com/vi/${videoId}/maxresdefault.jpg`,
		contentUrl: `https://www.youtube.com/watch?v=${videoId}`,
		embedUrl: `https://www.youtube.com/embed/${videoId}`,
	}
} : {};

const recipeSchema = {
	'@context': 'https://schema.org',
	'@type': 'Recipe',
	name: title,
	description,
	...(resolvedImage ? { image: resolvedImage } : {}),
	...(prepTime ? { prepTime } : {}),
	...(cookTime ? { cookTime } : {}),
	...(totalTime ? { totalTime } : {}),
	...(recipeYield ? { recipeYield } : {}),
	...(recipeCategory ? { recipeCategory } : {}),
	...(recipeCuisine ? { recipeCuisine } : {}),
	recipeIngredient,
	...(resolvedKeywords ? { keywords: resolvedKeywords } : {}),
	...videoSchema,
	...(recipeInstructions
		? {
				recipeInstructions: recipeInstructions.map((text, i) => ({
					'@type': 'HowToStep',
					position: i + 1,
					name: `Step ${i + 1}`,
					text,
					url: `${Astro.url}#step-${i + 1}`,
					...(resolvedImage ? { image: resolvedImage } : {}),
				})),
			}
		: {}),
	...(nutrition ? {
		nutrition: {
			'@type': 'NutritionInformation',
			...nutrition,
		}
	} : {}),
	author: {
		'@type': 'Person',
		name: author,
	},
};
---

<script type="application/ld+json" set:html={JSON.stringify(recipeSchema)} />
