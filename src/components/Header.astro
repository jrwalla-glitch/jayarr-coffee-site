---
import { SITE_TITLE } from '../consts';
import { CATEGORIES } from '../content.config';
import Search from './Search.astro';

const pathname = Astro.url.pathname;
const isHome = pathname === '/';
---

<header class:list={[
  'fixed top-0 left-0 right-0 z-50 transition-all duration-300',
  isHome ? 'bg-transparent' : 'bg-charcoal'
]} id="site-header">
  <nav class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="font-serif text-2xl font-bold text-cream tracking-tight hover:text-copper transition-colors">
      JayArr Coffee
    </a>
    <div class="hidden md:flex items-center gap-8">
      <!-- Articles with category dropdown -->
      <div class="relative group">
        <a href="/blog" class:list={[
          'text-sm uppercase tracking-widest transition-colors',
          pathname.startsWith('/blog') ? 'text-copper' : 'text-cream/80 hover:text-cream'
        ]}>Articles</a>
        <div class="absolute top-full left-1/2 -translate-x-1/2 pt-3 opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200">
          <div class="bg-charcoal-light border border-white/10 rounded-sm py-2 min-w-[160px] shadow-xl">
            {CATEGORIES.map((cat) => (
              <a
                href={`/blog/category/${cat.toLowerCase()}/`}
                class:list={[
                  'block px-4 py-2 text-sm transition-colors',
                  pathname === `/blog/category/${cat.toLowerCase()}/`
                    ? 'text-copper'
                    : 'text-cream/70 hover:text-cream hover:bg-white/5'
                ]}
              >
                {cat}
              </a>
            ))}
          </div>
        </div>
      </div>
      <a href="/explore" class:list={[
        'text-sm uppercase tracking-widest transition-colors',
        pathname.startsWith('/explore') ? 'text-copper' : 'text-cream/80 hover:text-cream'
      ]}>Explore</a>
      <a href="/videos" class:list={[
        'text-sm uppercase tracking-widest transition-colors',
        pathname.startsWith('/videos') ? 'text-copper' : 'text-cream/80 hover:text-cream'
      ]}>Videos</a>
      <a href="/about" class:list={[
        'text-sm uppercase tracking-widest transition-colors',
        pathname.startsWith('/about') ? 'text-copper' : 'text-cream/80 hover:text-cream'
      ]}>About</a>
      <!-- Search button -->
      <button id="search-btn" class="text-cream/60 hover:text-copper transition-colors" aria-label="Search">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607z"/></svg>
      </button>
      <a href="https://www.youtube.com/@jayarrcoffee" target="_blank" rel="noopener" class="text-cream/60 hover:text-copper transition-colors" aria-label="YouTube">
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
      </a>
    </div>
    <!-- Mobile: search + menu buttons -->
    <div class="flex items-center gap-4 md:hidden">
      <button id="mobile-search-btn" class="text-cream" aria-label="Search">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607z"/></svg>
      </button>
      <button id="mobile-menu-btn" class="text-cream" aria-label="Open menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </nav>
  <!-- Mobile menu -->
  <div id="mobile-menu" class="hidden md:hidden bg-charcoal/95 backdrop-blur-sm border-t border-white/10">
    <div class="px-6 py-4 flex flex-col gap-4">
      <a href="/blog" class="text-sm uppercase tracking-widest text-cream/80 hover:text-cream">Articles</a>
      <div class="pl-4 flex flex-col gap-2">
        {CATEGORIES.map((cat) => (
          <a href={`/blog/category/${cat.toLowerCase()}/`} class="text-sm text-cream/60 hover:text-cream transition-colors">
            {cat}
          </a>
        ))}
      </div>
      <a href="/explore" class="text-sm uppercase tracking-widest text-cream/80 hover:text-cream">Explore</a>
      <a href="/videos" class="text-sm uppercase tracking-widest text-cream/80 hover:text-cream">Videos</a>
      <a href="/about" class="text-sm uppercase tracking-widest text-cream/80 hover:text-cream">About</a>
    </div>
  </div>
</header>

<!-- Search modal -->
<Search />

<script>
  // Header scroll behavior - add solid bg on scroll
  const header = document.getElementById('site-header');
  const isHomePage = window.location.pathname === '/';

  if (isHomePage && header) {
    window.addEventListener('scroll', () => {
      if (window.scrollY > 100) {
        header.classList.remove('bg-transparent');
        header.classList.add('bg-charcoal/95', 'backdrop-blur-sm');
      } else {
        header.classList.remove('bg-charcoal/95', 'backdrop-blur-sm');
        header.classList.add('bg-transparent');
      }
    });
  }

  // Mobile menu toggle
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
