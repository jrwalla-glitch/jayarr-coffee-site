---
const today = new Date();
---

<footer class="bg-charcoal text-cream/70">
  <div class="max-w-6xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
      <!-- Brand -->
      <div>
        <h3 class="font-serif text-2xl font-bold text-cream mb-4">JayArr Coffee</h3>
        <p class="text-sm leading-relaxed">
          Exploring specialty coffee through science, scoring, and honest reviews. From origin to cup.
        </p>
      </div>
      <!-- Navigation -->
      <div>
        <h4 class="text-xs uppercase tracking-widest text-copper mb-4">Navigate</h4>
        <div class="flex flex-col gap-3">
          <a href="/blog" class="text-sm hover:text-cream transition-colors py-1">Articles</a>
          <a href="/videos" class="text-sm hover:text-cream transition-colors py-1">Videos</a>
          <a href="/about" class="text-sm hover:text-cream transition-colors py-1">About</a>
        </div>
      </div>
      <!-- Connect -->
      <div>
        <h4 class="text-xs uppercase tracking-widest text-copper mb-4">Connect</h4>
        <div class="flex flex-col gap-3">
          <a href="https://www.youtube.com/@jayarrcoffee" target="_blank" rel="noopener" class="text-sm hover:text-cream transition-colors py-1">YouTube</a>
          <a href="/rss.xml" class="text-sm hover:text-cream transition-colors py-1">RSS Feed</a>
        </div>
      </div>
    </div>
    <div class="border-t border-white/10 mt-12 pt-8 text-center text-xs text-cream/40">
      &copy; {today.getFullYear()} JayArr Coffee. All rights reserved.
    </div>
  </div>
</footer>
