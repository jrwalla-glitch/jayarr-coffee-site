---
import { getCollection } from 'astro:content';

interface Props {
	currentId: string;
	category?: string;
	limit?: number;
}

const { currentId, category, limit = 3 } = Astro.props;

const allPosts = await getCollection('deepbrew');

let related = allPosts
	.filter((p) => p.id !== currentId)
	.sort((a, b) => {
		const aMatch = category && a.data.category === category ? 1 : 0;
		const bMatch = category && b.data.category === category ? 1 : 0;
		if (aMatch !== bMatch) return bMatch - aMatch;
		return b.data.pubDate.valueOf() - a.data.pubDate.valueOf();
	})
	.slice(0, limit);
---

{related.length > 0 && (
	<aside class="db-related">
		<div class="db-related-divider"></div>
		<h2 class="db-related-heading">Continue Reading</h2>
		<div class="db-related-grid">
			{related.map((post) => (
				<a href={`/deep-brew/research/${post.id}/`} class="db-related-card group">
					<article>
						<span class="db-related-category">{post.data.category}</span>
						<h3 class="db-related-title">{post.data.title}</h3>
						<p class="db-related-desc">{post.data.description}</p>
						<span class="db-related-link">
							Read Article &rarr;
						</span>
					</article>
				</a>
			))}
		</div>
	</aside>
)}

<style>
	.db-related {
		padding-top: 0;
	}

	.db-related-divider {
		height: 1px;
		background: linear-gradient(90deg, transparent, var(--color-db-copper, #D27D2D), transparent);
		opacity: 0.3;
		margin-bottom: 2rem;
	}

	.db-related-heading {
		font-family: 'Cormorant Garamond', Georgia, serif;
		font-weight: 700;
		font-size: 1.5rem;
		color: var(--color-db-text, #E2E8F0);
		margin: 0 0 1.5rem;
	}

	.db-related-grid {
		display: grid;
		grid-template-columns: repeat(1, 1fr);
		gap: 1rem;
	}

	@media (min-width: 768px) {
		.db-related-grid {
			grid-template-columns: repeat(3, 1fr);
		}
	}

	.db-related-card {
		display: block;
		padding: 1.25rem;
		background: var(--color-db-surface, #161B22);
		border: 1px solid rgba(210, 125, 45, 0.15);
		border-radius: 8px;
		text-decoration: none;
		transition: border-color 0.3s;
	}

	.db-related-card:hover {
		border-color: rgba(210, 125, 45, 0.4);
	}

	.db-related-category {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.625rem;
		text-transform: uppercase;
		letter-spacing: 0.15em;
		color: var(--color-db-copper, #D27D2D);
		opacity: 0.7;
		background: rgba(210, 125, 45, 0.1);
		padding: 0.125rem 0.5rem;
		border-radius: 3px;
	}

	.db-related-title {
		font-family: 'Cormorant Garamond', Georgia, serif;
		font-weight: 700;
		font-size: 1.125rem;
		color: var(--color-db-text, #E2E8F0);
		margin: 0.75rem 0 0.5rem;
		line-height: 1.3;
		transition: color 0.2s;
	}

	.db-related-card:hover .db-related-title {
		color: var(--color-db-copper, #D27D2D);
	}

	.db-related-desc {
		font-size: 0.8125rem;
		color: var(--color-db-text-muted, #94A3B8);
		line-height: 1.5;
		margin: 0 0 0.75rem;
		display: -webkit-box;
		-webkit-line-clamp: 3;
		-webkit-box-orient: vertical;
		overflow: hidden;
	}

	.db-related-link {
		font-family: 'JetBrains Mono', monospace;
		font-size: 0.6875rem;
		text-transform: uppercase;
		letter-spacing: 0.2em;
		color: var(--color-db-copper, #D27D2D);
		opacity: 0.6;
		transition: opacity 0.2s;
	}

	.db-related-card:hover .db-related-link {
		opacity: 1;
	}
</style>
