---
interface Props {
	piece: 'origins' | 'methods' | 'flavors';
	context?: string;
}

const pieces: Record<string, { name: string; path: string; description: string; icon: string }> = {
	origins: {
		name: 'Coffee Origin Map',
		path: '/explore/origins/',
		description: 'Explore where the world\'s coffee grows on our interactive map.',
		icon: 'M12 21a9.004 9.004 0 0 0 8.716-6.747M12 21a9.004 9.004 0 0 1-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 0 1 7.843 4.582M12 3a8.997 8.997 0 0 0-7.843 4.582m15.686 0A11.953 11.953 0 0 1 12 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0 1 21 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0 1 12 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 0 1 3 12c0-1.605.42-3.113 1.157-4.418',
	},
	methods: {
		name: 'Brewing Methods Constellation',
		path: '/explore/methods/',
		description: 'See how brewing methods connect in our interactive star map.',
		icon: 'M11.48 3.499a.562.562 0 0 1 1.04 0l2.125 5.111a.563.563 0 0 0 .475.345l5.518.442c.499.04.701.663.321.988l-4.204 3.602a.563.563 0 0 0-.182.557l1.285 5.385a.562.562 0 0 1-.84.61l-4.725-2.885a.562.562 0 0 0-.586 0L6.982 20.54a.562.562 0 0 1-.84-.61l1.285-5.386a.562.562 0 0 0-.182-.557l-4.204-3.602a.562.562 0 0 1 .321-.988l5.518-.442a.563.563 0 0 0 .475-.345L11.48 3.5z',
	},
	flavors: {
		name: 'Flavor Bloom',
		path: '/explore/flavors/',
		description: 'Discover coffee flavors with our interactive tasting guide.',
		icon: 'M12 18.75a6 6 0 0 0 6-6v-1.5m-6 7.5a6 6 0 0 1-6-6v-1.5m6 7.5v3.75m-3.75 0h7.5M12 15a6.75 6.75 0 0 0 6.75-6.75V4.5a.75.75 0 0 0-.75-.75H6a.75.75 0 0 0-.75.75v3.75A6.75 6.75 0 0 0 12 15z',
	},
};

const { piece, context } = Astro.props;
const data = pieces[piece];
---

<aside class="explore-callout" aria-label={`Explore the ${data.name}`}>
	<div class="explore-callout-inner">
		<div class="explore-callout-icon">
			<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<path d={data.icon} />
			</svg>
		</div>
		<div class="explore-callout-content">
			<p class="explore-callout-label">Explore Further</p>
			<p class="explore-callout-title">{data.name}</p>
			<p class="explore-callout-desc">{context || data.description}</p>
			<a href={data.path} class="explore-callout-link">
				View Collection <span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</aside>

<style>
	.explore-callout {
		max-width: 720px;
		margin: 2rem auto;
		border: 1px solid rgba(26, 26, 26, 0.1);
		border-left: 3px solid var(--color-charcoal, #1A1A1A);
		border-radius: 2px;
		background: rgba(26, 26, 26, 0.02);
	}

	.explore-callout-inner {
		display: flex;
		gap: 1rem;
		padding: 1.25rem 1.5rem;
	}

	.explore-callout-icon {
		flex-shrink: 0;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-charcoal, #1A1A1A);
		opacity: 0.7;
	}

	.explore-callout-content {
		flex: 1;
		min-width: 0;
	}

	.explore-callout-label {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-charcoal, #1A1A1A);
		opacity: 0.5;
		margin: 0 0 0.25rem;
	}

	.explore-callout-title {
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--color-charcoal, #1A1A1A);
		margin: 0 0 0.25rem;
	}

	.explore-callout-desc {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--color-warm-gray, #6B6560);
		margin: 0 0 0.5rem;
	}

	.explore-callout-link {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-charcoal, #1A1A1A);
		text-decoration: none;
		transition: color 0.2s;
	}

	.explore-callout-link:hover {
		color: var(--color-copper, #C17A3A);
	}
</style>
