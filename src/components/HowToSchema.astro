---
interface HowToStep {
	name: string;
	text: string;
}

interface Props {
	name: string;
	description: string;
	steps: HowToStep[];
	totalTime?: string;
}

const { name, description, steps, totalTime } = Astro.props;

const howToSchema = {
	'@context': 'https://schema.org',
	'@type': 'HowTo',
	name,
	description,
	...(totalTime ? { totalTime } : {}),
	step: steps.map((step, i) => ({
		'@type': 'HowToStep',
		position: i + 1,
		name: step.name,
		text: step.text,
	})),
};
---

<script type="application/ld+json" set:html={JSON.stringify(howToSchema)} />
