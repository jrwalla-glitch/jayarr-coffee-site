---
interface Props {
	tool: 'water' | 'extraction' | 'calibrator';
	context?: string;
}

const tools: Record<string, { name: string; path: string; description: string; icon: string }> = {
	water: {
		name: 'Water Recipe Builder',
		path: '/deep-brew/water/',
		description: 'Map your water chemistry against 10 named recipes. Get DIY mineral concentrate instructions.',
		icon: 'M9.75 3.104v5.714a2.25 2.25 0 0 1-.659 1.591L5 14.5M9.75 3.104c-.251.023-.501.05-.75.082m.75-.082a24.301 24.301 0 0 1 4.5 0m0 0v5.714c0 .597.237 1.17.659 1.591L19.8 15.3M14.25 3.104c.251.023.501.05.75.082M19.8 15.3l-1.57.393A9.065 9.065 0 0 1 12 15a9.065 9.065 0 0 0-6.23.693L5 14.5m14.8.8 1.402 1.402c1.232 1.232.65 3.318-1.067 3.611A48.309 48.309 0 0 1 12 21c-2.773 0-5.491-.235-8.135-.687-1.718-.293-2.3-2.379-1.067-3.61L5 14.5',
	},
	extraction: {
		name: 'Extraction Diagnostic',
		path: '/deep-brew/extraction/',
		description: 'Describe what you taste. See where you are on the extraction curve. Get chemistry-backed fixes.',
		icon: 'M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z',
	},
	calibrator: {
		name: 'Grind-Roast Calibrator',
		path: '/deep-brew/calibrator/',
		description: 'Input your grinder, roast level, and origin. Get a calibrated starting point.',
		icon: 'M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z',
	},
};

const { tool, context } = Astro.props;
const data = tools[tool];
---

<aside class="deepbrew-callout" aria-label={`Try the ${data.name}`}>
	<div class="deepbrew-callout-inner">
		<div class="deepbrew-callout-icon">
			<svg width="24" height="24" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
				<path d={data.icon} />
			</svg>
		</div>
		<div class="deepbrew-callout-content">
			<p class="deepbrew-callout-label">Go Deep</p>
			<p class="deepbrew-callout-title">{data.name}</p>
			<p class="deepbrew-callout-desc">{context || data.description}</p>
			<a href={data.path} class="deepbrew-callout-link">
				Enter Deep Brew <span aria-hidden="true">&rarr;</span>
			</a>
		</div>
	</div>
</aside>

<style>
	.deepbrew-callout {
		max-width: 720px;
		margin: 2rem auto;
		border: 1px solid var(--color-db-border, rgba(210, 125, 45, 0.15));
		border-left: 3px solid var(--color-db-copper, #D27D2D);
		border-radius: 2px;
		background: var(--color-db-surface, #161B22);
	}

	.deepbrew-callout-inner {
		display: flex;
		gap: 1rem;
		padding: 1.25rem 1.5rem;
	}

	.deepbrew-callout-icon {
		flex-shrink: 0;
		width: 40px;
		height: 40px;
		display: flex;
		align-items: center;
		justify-content: center;
		color: var(--color-db-copper, #D27D2D);
	}

	.deepbrew-callout-content {
		flex: 1;
		min-width: 0;
	}

	.deepbrew-callout-label {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.6875rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.1em;
		color: var(--color-db-copper, #D27D2D);
		margin: 0 0 0.25rem;
	}

	.deepbrew-callout-title {
		font-family: 'Playfair Display', Georgia, serif;
		font-size: 1.125rem;
		font-weight: 700;
		color: var(--color-db-text, #E2E8F0);
		margin: 0 0 0.25rem;
	}

	.deepbrew-callout-desc {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.9375rem;
		line-height: 1.5;
		color: var(--color-db-text-muted, #94A3B8);
		margin: 0 0 0.5rem;
	}

	.deepbrew-callout-link {
		font-family: 'Inter', system-ui, sans-serif;
		font-size: 0.8125rem;
		font-weight: 600;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: var(--color-db-copper, #D27D2D);
		text-decoration: none;
		transition: color 0.2s;
	}

	.deepbrew-callout-link:hover {
		color: var(--color-db-copper-hover, #E89144);
	}
</style>
